# Copy to .env (this file is gitignored) and fill in real values.

# Postgres — leave blank to use the in-memory store (good for tests/demos).
# For Neon EU (free tier):
#   1. Sign up at https://neon.tech, region "Europe (Frankfurt)" or "Europe (Stockholm)"
#   2. Create a project; copy the connection string
#   3. Replace `postgresql://` with `postgresql+asyncpg://` (SQLAlchemy async driver)
#   4. Append `?ssl=require` if not already present (Neon requires TLS)
# Example:
#   DATABASE_URL=postgresql+asyncpg://user:pass@ep-foo-123.eu-central-1.aws.neon.tech/neondb?ssl=require
DATABASE_URL=

# CORS origins (comma-separated isn't supported here — set via env list if needed)
# Defaults already include http://localhost:3000 and http://127.0.0.1:3000

# Default protokoll-number initials until magic-link auth ships in M4
DEFAULT_USER_INITIALS=GC

# Token the weekly news scraper must present on POST /news/ingest.
# Generate any random string (e.g. `python -c "import secrets; print(secrets.token_urlsafe(32))"`)
# Leave blank to disable the ingest endpoint (it returns 503).
NEWS_INGEST_TOKEN=

# Email that gets admin (moderation) access. Single user for v1.
ADMIN_EMAIL=carina@synahus.se

# Base URL of the web frontend (used in magic-link emails).
WEB_BASE_URL=http://localhost:3000

# Comma-separated domains rejected on public submission forms (news + members).
# Login is NOT affected — admins on a blocked domain can still log in.
BLOCKED_SUBMITTER_DOMAINS=synahus.se
